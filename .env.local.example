# Folio · environment variables
# Copy to .env.local and fill in real values. .env.local is in .gitignore.

# ─── Database (Neon Postgres + pgvector) ───
# console.neon.tech → folio project → Connection Details → "Pooled connection"
DATABASE_URL="postgresql://user:pass@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── Auth (Clerk) ───
# dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Webhook signing secret — set after creating the Webhook endpoint in Clerk
# (Clerk Dashboard → Webhooks → Create Endpoint → Signing Secret)
CLERK_WEBHOOK_SECRET="whsec_..."

# Clerk URL conventions (defaults are fine)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/studio"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/studio"

# ─── LLM (Anthropic Claude — Assistant) ───
# console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY="sk-ant-..."

# ─── LLM (OpenAI — embeddings) ───
# platform.openai.com → API Keys
OPENAI_API_KEY="sk-..."
